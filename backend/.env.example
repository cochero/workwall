# Workwall backend configuration
# Copy to .env and fill in real values. Never commit .env.

PORT=5300
NODE_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=workwall
DB_PASSWORD=
DB_NAME=workwall

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# local = store files under backend/uploads (dev)
# s3    = Contabo Object Storage (production)
STORAGE_DRIVER=s3
S3_ENDPOINT=https://eu2.contabostorage.com
S3_REGION=eu2
S3_BUCKET=workwall
S3_ACCESS_KEY=
S3_SECRET_KEY=

MAX_UPLOAD_MB=50
